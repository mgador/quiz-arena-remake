# MongoDB connection string (required)
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# Example: mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# MongoDB database name (optional, defaults to "quiz-arena")
MONGODB_DB_NAME=quiz-arena

# NextAuth.js canonical URL (required)
# Local: http://localhost:3000
# Vercel: https://<your-project>.vercel.app
NEXTAUTH_URL=http://localhost:3000

# NextAuth.js secret for signing JWTs (required)
# Must be at least 32 characters — never use a placeholder in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace-with-a-long-random-secret
